{
	"compilerOptions": {
		"strict": true,
		"lib": ["ES2020"],
		"target": "ES2019",
		"module": "CommonJS",
		"outDir": "dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"types": ["node", "mocha"]
	},
	"include": ["types/*.ts", "src/**/*.ts", "test/**/*.js"]
}
